# Lincle Environment Variables

# Server
ENV=development
PORT=8080

# Database (SQLite for dev, PostgreSQL for production NAS)
DATABASE_URL=file:./data/lincle.db?_journal_mode=WAL&_busy_timeout=5000&_foreign_keys=on

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
