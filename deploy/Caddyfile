{
    # Cloudflare Tunnel handles HTTPS — Caddy only serves HTTP internally
    auto_https off
}

:80 {
    # API proxy
    handle /api/* {
        reverse_proxy lincle-api:8080
    }

    handle /sse/* {
        reverse_proxy lincle-api:8080
    }

    handle /health {
        reverse_proxy lincle-api:8080
    }

    # Static files (item icons, uploads)
    handle /static/* {
        reverse_proxy lincle-api:8080
    }

    handle /uploads/* {
        reverse_proxy lincle-api:8080
    }

    # Frontend (Flutter Web) — static files with SPA fallback
    handle {
        root * /srv/web
        try_files {path} /index.html
        file_server

        # Security headers
        header {
            X-Content-Type-Options nosniff
            X-Frame-Options DENY
            Referrer-Policy strict-origin-when-cross-origin
        }
    }
}
